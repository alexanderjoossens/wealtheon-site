# ── Wealtheon × LinkedIn syndication ─────────────────────────
# Copy this file to ".env" and fill in the values. The .env file is
# gitignored. With these unset, the site runs normally and the /news
# page simply shows published posts only (none until configured).
# See LINKEDIN_SETUP.md for how to obtain each value.

# From your LinkedIn Developer App (Auth tab)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Your company page's organization URN. Format: urn:li:organization:<id>
# Find the numeric id via the admin URL: linkedin.com/company/<id>/admin/
LINKEDIN_ORG_URN=urn:li:organization:0000000

# Versioned API date (YYYYMM). Bump when LinkedIn sunsets a version.
LINKEDIN_API_VERSION=202505

# OAuth redirect URI — must match EXACTLY what is registered in the app.
# Used only by scripts/linkedin-auth.js (one-off token bootstrap).
LINKEDIN_REDIRECT_URI=http://localhost:5599/callback

# OAuth scopes requested during the bootstrap (space-separated).
LINKEDIN_SCOPES=r_organization_social r_organization_admin

# Protects POST /api/sync. Set to any long random string.
SYNC_TOKEN=

# How often the in-process poller checks LinkedIn, in minutes.
POLL_MINUTES=15
